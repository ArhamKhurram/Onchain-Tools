# frontend/.env — copy to .env. Only VITE_ (publishable) values belong here.
# NEVER put a service_role key in any VITE_ variable (the app throws if you do).
#
# DB per environment:
#   DEV  -> onchain-tools-dev  (ref zcvubfadvdwjxgodznxh)
#   PROD -> onchain-tools      (ref vmlxyqzjdaegkfylxfka)

# Backend origin (no trailing path). Used for REST (/api) and WebSocket (/ws).
# In production this MUST point at your long-lived backend host, e.g.
#   VITE_API_URL=https://api.your-domain.com
# WebSockets do not run on Vercel, so this cannot be the Vercel URL.
VITE_API_URL=http://localhost:3001

# DEV:
#   VITE_SUPABASE_URL=https://zcvubfadvdwjxgodznxh.supabase.co
# PROD:
#   VITE_SUPABASE_URL=https://vmlxyqzjdaegkfylxfka.supabase.co
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: absolute URL to a static announcements.json (open CORS). If unset,
# the in-app announcement modal is disabled.
# VITE_ANNOUNCEMENTS_URL=https://raw.githubusercontent.com/<org>/<repo>/main/announcements.json
