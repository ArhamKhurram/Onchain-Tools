# backend/.env — copy to .env and fill secrets.
# The backend loads THIS file (backend/.env), not the repo-root .env.
#
# DB per environment:
#   DEV  -> onchain-tools-dev  (ref zcvubfadvdwjxgodznxh)
#   PROD -> onchain-tools      (ref vmlxyqzjdaegkfylxfka)

# OCT deployment mode: hosted (multi-tenant) or local (single-user)
OCT_MODE=hosted
PORT=3001
# Comma-separated allowed CORS/WS origins. In production include your Vercel URL,
# e.g. ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# DEV:
#   SUPABASE_URL=https://zcvubfadvdwjxgodznxh.supabase.co
# PROD:
#   SUPABASE_URL=https://vmlxyqzjdaegkfylxfka.supabase.co
# NOTE: the app reads SUPABASE_SERVICE_KEY (not SUPABASE_SERVICE_ROLE_KEY).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# 64-char hex (32 bytes). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: if this changes, previously-encrypted Discord tokens can't be decrypted.
# Use a DISTINCT key per environment.
TOKEN_ENCRYPTION_KEY=
