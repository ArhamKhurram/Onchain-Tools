# backend/.env — copy to .env and fill secrets.
# The backend loads THIS file (backend/.env), not the repo-root .env.
#
# DB per environment:
#   DEV  -> onchain-tools-dev  (ref zcvubfadvdwjxgodznxh)
#   PROD -> onchain-tools      (ref vmlxyqzjdaegkfylxfka)

# OCT deployment mode: hosted (multi-tenant) or local (single-user)
OCT_MODE=hosted
PORT=3001
# Comma-separated allowed CORS/WS origins. In production include your Vercel URL,
# e.g. ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# DEV:
#   SUPABASE_URL=https://zcvubfadvdwjxgodznxh.supabase.co
# PROD:
#   SUPABASE_URL=https://vmlxyqzjdaegkfylxfka.supabase.co
# NOTE: the app reads SUPABASE_SERVICE_KEY (SUPABASE_SERVICE_ROLE_KEY also accepted).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# 64-char hex (32 bytes). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: if this changes, previously-encrypted Discord tokens can't be decrypted.
# Use a DISTINCT key per environment.
TOKEN_ENCRYPTION_KEY=

# --- FOMO (fomo.family) integration ---
# Shared service-account credentials. Bootstrap options (pick one):
#   1. One-time SQL seed (recommended for prod):
#        update public.fomo_poll_state set refresh_token = 'ap1wp_...' where id = true;
#      After first boot the poller reads DB-first and auto-rotates into fomo_poll_state.
#   2. Set FOMO_REFRESH_TOKEN here for first boot only, then remove once DB has a token.
#
# How to obtain FOMO_REFRESH_TOKEN (one-time, from a logged-in fomo.family session):
#   1. Open https://fomo.family in Chrome, sign in (Apple/Google via Privy).
#   2. DevTools → Application → Cookies → https://fomo.family
#   3. Copy the `privy-refresh-token` cookie value (starts with ap1wp_…).
#   4. Paste below OR seed into fomo_poll_state (option 1). Never commit real tokens.
#
# Local Playwright setup (required for API calls):
#   cd backend && npx playwright install chromium
#
# Railway: nixpacks.toml installs Chromium + OS libs at build time.
# Optional env:
#   FOMO_POLL_INTERVAL_MS=10000   — fan-out poller interval (default 10s)
#   FOMO_ENSURE_FOLLOWS=true      — auto-follow tracked users on shared account (default on)
#
# The rest of the FOMO_* vars improve Cloudflare cold-start reliability (optional).
FOMO_REFRESH_TOKEN=
FOMO_POLL_INTERVAL_MS=
FOMO_ENSURE_FOLLOWS=
FOMO_PRIVY_APP_ID=
FOMO_PRIVY_CLIENT=
FOMO_PRIVY_CLIENT_ID=
FOMO_PRIVY_CA_ID=
FOMO_PRIVY_TOKEN=
FOMO_PRIVY_SESSION=
FOMO_CF_CLEARANCE=
FOMO_CF_BM=
FOMO_CF_UVID=

# --- Birdeye portfolio (stats, PnL chart/calendar, holdings, activity) ---
# Preferred when set — overrides GMGN for the Portfolio tab. Get a key at https://bds.birdeye.so
# Supports solana, robinhood, ethereum, base, bsc (see docs.birdeye.so).
BIRDEYE_API_KEY=

# --- GMGN token enrichment (Robinhood + snapshot API) ---
# Obtain from https://gmgn.ai/ai/generateapi (gmgn-cli config can write ~/.config/gmgn/.env).
# Railway: set GMGN_API_KEY on the backend service (never commit the key).
# Robinhood-chain enrichment uses GMGN first; DexScreener remains the fallback.
GMGN_API_KEY=
# Optional: request-signing private key (PEM) for GMGN critical-auth routes.
# Required for Portfolio holdings (GET /v1/user/wallet_holdings). Stats, activity, and PnL chart work with API key only.
# Generate with: openssl genpkey -algorithm ed25519 -out gmgn_private.pem
# Upload the matching public key at https://gmgn.ai/ai when creating the API key.
# Railway: paste PEM with literal newlines, or use \n escapes in a single line.
GMGN_PRIVATE_KEY=

# --- Missed-runner alerts (on-chain wallet balance checks) ---
# Solana balance checks via Helius (https://helius.dev). Required for SOL missed-runner alerts.
HELIUS_API_KEY=
# Optional: Alchemy key for EVM balanceOf on eth/bsc/base (falls back to public RPC if unset).
ALCHEMY_API_KEY=
# Optional: poller interval in ms (default 180000 = 3 min).
MISSED_RUNNER_POLL_INTERVAL_MS=
