# backend/.env — copy to .env and fill secrets.
# The backend loads THIS file (backend/.env), not the repo-root .env.
#
# DB per environment:
#   DEV  -> onchain-tools-dev  (ref zcvubfadvdwjxgodznxh)
#   PROD -> onchain-tools      (ref vmlxyqzjdaegkfylxfka)

# OCT deployment mode: hosted (multi-tenant) or local (single-user)
OCT_MODE=hosted
PORT=3001
# Comma-separated allowed CORS/WS origins. In production include your Vercel URL,
# e.g. ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# DEV:
#   SUPABASE_URL=https://zcvubfadvdwjxgodznxh.supabase.co
# PROD:
#   SUPABASE_URL=https://vmlxyqzjdaegkfylxfka.supabase.co
# NOTE: the app reads SUPABASE_SERVICE_KEY (SUPABASE_SERVICE_ROLE_KEY also accepted).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# 64-char hex (32 bytes). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: if this changes, previously-encrypted Discord tokens can't be decrypted.
# Use a DISTINCT key per environment.
TOKEN_ENCRYPTION_KEY=

# --- FOMO (fomo.family) integration ---
# Shared service-account credentials. Bootstrap options (pick one):
#   1. One-time SQL seed (recommended for prod):
#        update public.fomo_poll_state set refresh_token = 'ap1wp_...' where id = true;
#      After first boot the poller reads DB-first and auto-rotates into fomo_poll_state.
#   2. Set FOMO_REFRESH_TOKEN here for first boot only, then remove once DB has a token.
# The rest of the FOMO_* vars improve Cloudflare cold-start reliability.
# Requires Chromium (Playwright) available at runtime — see nixpacks note.
FOMO_REFRESH_TOKEN=
FOMO_PRIVY_APP_ID=
FOMO_PRIVY_CLIENT=
FOMO_PRIVY_CLIENT_ID=
FOMO_PRIVY_CA_ID=
FOMO_PRIVY_TOKEN=
FOMO_PRIVY_SESSION=
FOMO_CF_CLEARANCE=
FOMO_CF_BM=
FOMO_CF_UVID=
