{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build -w frontend",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/dashboard/(.*)", "destination": "/index.html" },
    { "source": "/dashboard", "destination": "/index.html" }
  ]
}
